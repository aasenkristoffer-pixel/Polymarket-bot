{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install fastapi uvicorn httpx python-dotenv pydantic"
  },
  "deploy": {
    "startCommand": "uvicorn polymarket_copy_bot:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
